# Example environment for the Longevity Health Analytics Platform (local dev).
# Copy to .env.local and adjust. NEVER put real secrets or patient data here.
# Real secrets belong in a secret manager, not in any committed file.

# ---- App mode ----------------------------------------------------------------
# "development" enables the local OIDC dev provider. The dev provider REFUSES to
# run when APP_ENV=production, so it can never impersonate a real integration.
APP_ENV=development

# ---- Database ----------------------------------------------------------------
# Local Postgres from docker-compose. Host port 55433 (55432 = hadp-alpha).
# Migrations/admin connect as the superuser; the application connects as the
# non-superuser role `hadp_app` so PostgreSQL row-level security is enforced.
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:55433/hadp
APP_DATABASE_URL=postgresql+psycopg://hadp_app:hadp_app@127.0.0.1:55433/hadp
TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:55433/hadp_test
TEST_APP_DATABASE_URL=postgresql+psycopg://hadp_app:hadp_app@127.0.0.1:55433/hadp_test

# ---- Redis (background jobs) -------------------------------------------------
REDIS_URL=redis://127.0.0.1:56379/0

# ---- Object storage (S3-compatible; MinIO locally, EU region in prod) --------
S3_ENDPOINT_URL=http://127.0.0.1:59000
S3_REGION=eu-central-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_SOURCE_DOCUMENTS=hadp-source-documents

# ---- Sessions ----------------------------------------------------------------
# Random per-environment value. The placeholder here is NOT a real secret.
SESSION_SECRET=dev-only-not-a-secret-change-me

# ---- Web app -----------------------------------------------------------------
API_BASE_URL=http://127.0.0.1:8000
WEB_BASE_URL=http://127.0.0.1:3000
NEXT_PUBLIC_APP_ENV=development

# ---- OIDC (production only; left configurable per CLAUDE.md) ------------------
# Do NOT fill these for local dev. A production OIDC provider is a gated vendor
# decision. When set with APP_ENV=production, the real provider is used instead
# of the dev provider.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
