{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "uv",
      "runtimeArgs": [
        "--project",
        "apps/api",
        "run",
        "uvicorn",
        "hadp_api.main:app",
        "--reload",
        "--port",
        "8000"
      ],
      "port": 8000,
      "autoPort": false
    },
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@hadp/web", "exec", "next", "dev"],
      "autoPort": true
    },
    {
      "name": "web-preview",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "--filter",
        "@hadp/web",
        "exec",
        "next",
        "dev",
        "-p",
        "3007"
      ],
      "port": 3007
    }
  ]
}
